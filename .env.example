# Этот файл нужен только для ЛОКАЛЬНОГО запуска без Docker (uvicorn/worker
# напрямую из venv, см. CLAUDE.md/README.md) — тогда Postgres и Redis слушают
# на localhost, поэтому и адреса ниже локальные.
#
# При запуске через `docker compose up` эти же переменные задаются прямо в
# docker-compose.yml (в блоке x-app-env) и указывают не на localhost, а на
# имена сервисов — postgres/redis, — потому что каждый контейнер видит
# остальные только по именам сервисов в общей сети compose. Этот .env файл
# в таком случае не используется вообще.

# Строка подключения к PostgreSQL
# Формат: postgresql://<пользователь>:<пароль>@<хост>:<порт>/<имя_бд>
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Строка подключения к Redis (брокер очереди задач RQ)
REDIS_URL=redis://localhost:6379/0
