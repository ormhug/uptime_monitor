# Образ для процесса воркера (RQ SimpleWorker).
#
# Код и зависимости у API и воркера общие, поэтому образ почти идентичен
# Dockerfile — на этом этапе просто дублируем его с другой CMD, это проще,
# чем городить multi-stage/общий базовый образ ради экономии пары строк.
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["python", "-m", "app.worker"]
